{
  "browser": "chromium",
  "headless": true,
  "url": "https://quotes.toscrape.com/js/",
  "waitUntil": "networkidle",
  "extraWaitMs": 1500,
  "viewport": {
    "width": 1440,
    "height": 2200
  },
  "actions": [
    {
      "type": "waitForSelector",
      "selector": ".quote"
    },
    {
      "type": "scroll",
      "to": "bottom",
      "delayMs": 1000
    }
  ],
  "extract": {
    "pageText": true,
    "fields": {
      "title": {
        "type": "pageTitle"
      },
      "finalUrl": {
        "type": "pageUrl"
      }
    },
    "collection": {
      "selector": ".quote",
      "limit": 5,
      "fields": {
        "text": {
          "selector": ".text",
          "type": "text"
        },
        "author": {
          "selector": ".author",
          "type": "text"
        },
        "tags": {
          "selector": ".tag",
          "type": "text",
          "multiple": true
        }
      }
    }
  },
  "output": {
    "jsonPath": "output/quotes-js.json",
    "csvPath": "output/quotes-js.csv",
    "htmlPath": "output/quotes-js.html",
    "screenshotPath": "output/quotes-js.png",
    "fullPageScreenshot": true
  }
}
